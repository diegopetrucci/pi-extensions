{
  "name": "@diegopetrucci/pi-annotate-git-diff",
  "version": "0.1.4",
  "description": "A standalone pi extension that adds /annotate-git-diff, a native Glimpse UI for annotating git diffs and sending feedback to the editor.",
  "keywords": [
    "pi-package",
    "pi",
    "annotate",
    "git",
    "diff",
    "review"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/diegopetrucci/pi-extensions.git",
    "directory": "extensions/annotate-git-diff"
  },
  "files": [
    "index.ts",
    "clipboard.ts",
    "git.ts",
    "prompt.ts",
    "quiet-glimpse.ts",
    "types.ts",
    "ui.ts",
    "watch.ts",
    "web",
    "glimpseui.d.ts",
    "README.md",
    ".pi-fleet-tested-version"
  ],
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "index.ts"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "dependencies": {
    "@tailwindcss/browser": "^4.3.2",
    "glimpseui": "^0.8.1",
    "monaco-editor": "0.52.2"
  },
  "type": "module",
  "engines": {
    "node": ">=22.19.0"
  }
}
